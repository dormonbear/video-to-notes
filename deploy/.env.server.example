# 服务端 .env 模板 —— 复制到 /opt/video-to-notes/.env 并填值
# systemd EnvironmentFile 格式：KEY=VALUE，值不要加引号。

TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=

# 国内 VPS 上 Google Gemini 被区域封锁，需走你在 VPS 上跑的代理。
# 改成你的代理端口（Clash 默认混合端口常见为 7890）。
MODEL=google/gemini-2.5-flash
OPENROUTER_PROXY=http://127.0.0.1:7890

# 若不想配代理：用国内可直连的模型，并关代理：
# MODEL=z-ai/glm-4.6v
# OPENROUTER_PROXY=direct

# 笔记仓库：VAULT_PATH 是 VPS 上 clone 的 git 仓库目录；笔记写进 NOTE_SUBDIR。
# 开启 GIT_SYNC 后，每写一篇笔记自动 git add/commit/push。
VAULT_PATH=/opt/video-to-notes/vault
NOTE_SUBDIR=video-notes
GIT_SYNC=true

TMP_DIR=/tmp/video-to-notes
