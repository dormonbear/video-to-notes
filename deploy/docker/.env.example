# Docker 部署 .env —— 复制为 deploy/docker/.env 并填值（不要入库）

TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=

MODEL=google/gemini-2.5-flash
# host 网络下指向宿主 Clash 混合端口（mbp-server mihomo = 7890）
OPENROUTER_PROXY=http://127.0.0.1:7890

NOTE_FORMAT=blog
# 容器内挂载点（compose 把 ./vault 挂到 /vault）
VAULT_PATH=/vault
NOTE_SUBDIR=src/content/posts
GIT_SYNC=true

TMP_DIR=/tmp/video-to-notes
