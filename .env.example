# Telegram bot token，@BotFather 新建 bot 后获得
TELEGRAM_BOT_TOKEN=

# OpenRouter API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter 模型 id。
#   google/gemini-2.5-flash  质量最好，但被区域封锁，需走代理（见 OPENROUTER_PROXY）
#   z-ai/glm-4.6v            国内直连可用，无需代理
MODEL=google/gemini-2.5-flash

# OpenRouter 请求走的代理。默认走本机 Clash 混合端口（已配 openrouter.ai -> AI 美国线路）。
# 用 z-ai/glm-4.6v 等国内可直连模型时，设为 direct 关闭代理。
OPENROUTER_PROXY=http://127.0.0.1:7897

# Obsidian vault 根目录的绝对路径
VAULT_PATH=/Users/dormonzhou/Library/CloudStorage/OneDrive-EnglishOneAG/Documents/Yingfu

# 输出格式：obsidian（写 vault）或 blog（写 AstroPaper 博客仓库的 src/content/blog 并 push）
NOTE_FORMAT=obsidian
# blog 模式：草稿发布（true 则文章 draft 不上线）
BLOG_DRAFT=false
# blog 模式：区分用的 tag
BLOG_TAG=video-note

# vault 内目标子文件夹（相对 VAULT_PATH），笔记写到这里。
# blog 模式应设为 src/content/blog
NOTE_SUBDIR=video-notes

# 写完笔记是否在 VAULT_PATH 里 git add/commit/push（服务器部署用，见 DEPLOY.md）。
# 本机直写 vault 时留空/false。
GIT_SYNC=false

# 视频临时下载目录
TMP_DIR=/tmp/video-to-notes
